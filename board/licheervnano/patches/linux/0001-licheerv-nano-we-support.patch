index 000000000000..99e3a574fafa
--- /dev/null
+++ b/arch/riscv/boot/dts/sophgo/sg2002-licheerv-nano-we.dts
@@ -0,0 +1,57 @@
+// SPDX-License-Identifier: (GPL-2.0 OR MIT)
+/*
+ * Device tree for LicheeRV Nano WE (WiFi + Ethernet variant)
+ */
+
+#include "sg2002-licheerv-nano-b.dts"
+
+/ {
+	model = "LicheeRV Nano WE";
+	compatible = "sipeed,licheerv-nano-we", "sipeed,licheerv-nano",
+		     "sophgo,sg2002";
+};
+
+&usb {
+	dr_mode = "peripheral";
+	status = "okay";
+};
+
+/* Ethernet with fixed-link */
+&mdio {
+	status = "okay";
+};
+
+&gmac0 {
+	/delete-property/ phy-handle;
+	status = "okay";
+
+	fixed-link {
+		speed = <100>;
+		full-duplex;
+	};
+};
+
+/* SDIO for WiFi module (AIC8800) on SD1 */
+&sdhci1 {
+	compatible = "sophgo,sg2002-dwcmshc";
+	pinctrl-0 = <&sdio_wifi_cfg>;
+	pinctrl-names = "default";
+	bus-width = <4>;
+	no-mmc;
+	no-sd;
+	non-removable;
+	status = "okay";
+};
+
+&pinctrl {
+	sdio_wifi_cfg: sdio-wifi-cfg {
+		sdio-pins {
+			pinmux = <PINMUX(PIN_SD1_D3, 0)>,
+				 <PINMUX(PIN_SD1_D2, 0)>,
+				 <PINMUX(PIN_SD1_D1, 0)>,
+				 <PINMUX(PIN_SD1_D0, 0)>,
+				 <PINMUX(PIN_SD1_CMD, 0)>,
+				 <PINMUX(PIN_SD1_CLK, 0)>;
+		};
+	};
+};
